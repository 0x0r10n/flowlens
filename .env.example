# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── gRPC (Yellowstone / Chainstack) ──────────────────────────────────────────
GEYSER_ENDPOINT=https://your-chainstack-geyser-endpoint
GEYSER_X_TOKEN=your-x-token

# ─── RPC fallback (used only if GEYSER_ENDPOINT is not set) ───────────────────
RPC_URL=https://solana-mainnet.core.chainstack.com/YOUR_KEY_HERE

# ─── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=info          # trace | debug | info | warn | error
# NODE_ENV=production     # disables pino-pretty, enables JSON logs

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for WebSocket + REST.
# Leave unset to allow all origins (fine for dev, restrict in prod).
# CORS_ORIGINS=https://your-trading-app.com,https://app.example.com

# ─── Admin endpoints ──────────────────────────────────────────────────────────
# If set, /admin/* routes require: Authorization: Bearer <ADMIN_SECRET>
# Leave unset to disable auth (dev only).
# ADMIN_SECRET=your-strong-secret-here

# ─── WebSocket public URL (used by /rooms discovery endpoint) ─────────────────
# Set this to the publicly reachable WebSocket URL of this server.
# PUBLIC_WS_URL=wss://your-api.example.com

# ─── Alerts ───────────────────────────────────────────────────────────────────
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── Redis (optional — enables horizontal scaling + snapshot persistence) ─────
# REDIS_URL=redis://localhost:6379
